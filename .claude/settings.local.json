{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "mcp__serena__activate_project",
      "mcp__sequential-thinking__sequentialthinking",
      "Skill(humanization-review)",
      "Skill(parallel-refactor)"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-write-manuscript.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-check.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-stop-reminder.sh"
          }
        ]
      }
    ]
  },
  "preferences": {
    "outputStyle": "explanatory",
    "autoUpdates": false
  },
  "remote": {
    "defaultEnvironmentId": "env_01A7vRYbG3QUdY1RHnudoLax"
  }
}
